% Gemini theme
% https://github.com/anishathalye/gemini

% ====================
% Definitions
% ====================

% Color Palette
% From https://www.wm.edu/brand/visual-brand/color-palette/
% Primary
\definecolor{wmgreen}{RGB}{0, 78, 56}
\definecolor{wmgold}{RGB}{183, 146, 87}
\definecolor{wmsilver}{RGB}{216, 220, 219}
\definecolor{wmwhite}{RGB}{255,255,255}
\definecolor{wmblack}{RGB}{0,0,0}
% Secondary Greens
\definecolor{darkgreen}{RGB}{17,87,64}
\definecolor{griffingreen}{RGB}{40,70,62}
\definecolor{patina}{RGB}{118,161,144}
\definecolor{sage}{RGB}{184,221,177}
\definecolor{moss}{RGB}{120,157,74}
% Tertiary Colors
\definecolor{midnightblue}{RGB}{13,61,73}
\definecolor{marineblue}{RGB}{36,123,141}
\definecolor{slateblue}{RGB}{116,153,193}
\definecolor{royalpurple}{RGB}{103,62,101}
\definecolor{brickred}{RGB}{150,74,55}


% ====================
% Theme
% ====================

% Basic colors
\setbeamercolor{palette primary}{fg=wmblack,bg=wmwhite}
\setbeamercolor{palette secondary}{fg=wmblack,bg=wmwhite}
\setbeamercolor{palette tertiary}{bg=wmblack,fg=wmwhite}
\setbeamercolor{palette quaternary}{fg=wmblack,bg=wmwhite}
\setbeamercolor{structure}{fg=wmgreen}

% Headline
\setbeamercolor{headline}{fg=wmwhite,bg=wmgreen}
\setbeamercolor{headline rule}{bg=wmgold}

% Block
\setbeamercolor{block title}{fg=wmgreen,bg=wmwhite}
\setbeamercolor{block separator}{bg=wmgold}
\setbeamercolor{block body}{fg=wmblack,bg=wmwhite}

% Alert Block
\setbeamercolor{block alerted title}{fg=wmwhite,bg=darkgreen}
\setbeamercolor{block alerted separator}{bg=wmgold}
\setbeamercolor{block alerted body}{fg=wmblack,bg=wmsilver}

% Heading
\setbeamercolor{heading}{fg=wmgreen}

% Itemize
\setbeamercolor{item}{fg=wmgold}

% Bibliography
\setbeamercolor{bibliography item}{fg=wmgreen}
\setbeamercolor{bibliography entry author}{fg=wmgreen}
\setbeamercolor{bibliography entry title}{fg=black}
\setbeamercolor{bibliography entry location}{fg=griffingreen}
\setbeamercolor{bibliography entry note}{fg=griffingreen}
\setbeamertemplate{bibliography entry article}{}
\setbeamertemplate{bibliography entry title}{}
\setbeamertemplate{bibliography entry location}{}
\setbeamertemplate{bibliography entry note}{}
